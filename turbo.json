{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },

    "cli#build": {
      "dependsOn": ["^build"],
      "env": [],
      "cache": false
    },
    "web#build":{
      "dependsOn": ["^build"],
      "env": [],
      "cache": false
    },
    "docs#build":{
      "dependsOn": ["^build"],
      "env": [],
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
