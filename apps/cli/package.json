{
  "name": "@archaeo/cli",
  "packageManager": "yarn@4.13.0",
  "description": "Query your git history in plain English",
  "type": "commonjs",
  "bin": {
    "archaeo": "./dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "lint": "eslint src/",
