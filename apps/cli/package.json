    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.1",
    "ignore": "^7.0.5",
    "minimatch": "^10.2.5",
    "ora": "^9.3.0",
    "simple-git": "^3.36.0",
